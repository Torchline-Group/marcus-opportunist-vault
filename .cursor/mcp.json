{
  "mcpServers": {
    "scraper": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": { "FIRECRAWL_API_KEY": "YOUR_KEY" }
    },
    "deploy": {
      "command": "npx",
      "args": ["vercel", "deploy", "--prod", "--yes"]
    },
    "shopify": {
      "command": "node",
      "args": ["./scripts/shopify-populate.js"]
    }
  }
}
